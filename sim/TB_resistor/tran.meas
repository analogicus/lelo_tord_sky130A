* Measure TB_resistor
.control

load {cicname}.raw

echo "MEAS_START"

meas tran vdd_9ns find v(vdd) at=9ns
* meas tran vss_9ns find v(vss) at=9ns
meas tran idd_9ns find i(vdd) at=9ns
* meas tran iss_9ns find i(vss) at=9ns

echo "MEAS_END"

* set wr_singlescale
* set wr_vecnames
* option numdgt = 5

* wrdata {cicname}.out
* + v(vdd) i(vdd)
* + v(vss) i(vss)

.endc
